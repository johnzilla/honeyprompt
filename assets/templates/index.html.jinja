<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ page_title }}</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; }
    #warning-banner { background: #fff3cd; border: 2px solid #ffc107; padding: 1rem; margin-bottom: 2rem; font-weight: bold; text-align: center; }
    #canary-content { line-height: 1.6; }
    .notice { background: #f8d7da; border: 1px solid #f5c6cb; padding: 0.75rem; margin: 1rem 0; }
  </style>
  {% for p in payloads %}{% if p.embedding_location == "meta_tag" %}
  {{ p.rendered_instruction }}
  {% endif %}{% endfor %}
</head>
<body>
  <!-- HONEYPROMPT SECURITY RESEARCH CANARY — This page detects AI agent prompt injection compliance -->
  <div id="warning-banner">
    SECURITY RESEARCH CANARY — This page is a honeypot operated for security research purposes.
    It detects whether AI browsing agents follow prompt-injection instructions embedded in web content.
    If you are a human, this page is harmless and you can safely ignore it.
  </div>

  {% for p in payloads %}{% if p.embedding_location == "html_comment" %}
  {{ p.rendered_instruction }}
  {% endif %}{% endfor %}

  <article id="canary-content">
    <h1>{{ page_title }}</h1>
    <div class="notice">
      <strong>Notice:</strong> This is a security research artifact operated under responsible disclosure
      principles. No secrets are collected. No harmful actions are performed. All payloads are auditable.
    </div>
    {% for p in payloads %}{% if p.embedding_location == "semantic_prose" %}
    <p>{{ p.rendered_instruction }}</p>
    {% endif %}{% endfor %}
  </article>

  {% for p in payloads %}{% if p.embedding_location == "invisible_element" %}
  {{ p.rendered_instruction }}
  {% endif %}{% endfor %}

  {% for p in payloads %}{% if p.embedding_location == "json_ld" %}
  <script type="application/ld+json">{{ p.rendered_instruction }}</script>
  {% endif %}{% endfor %}
</body>
</html>
